{
  "expo": {
    "name": "SettleMint",
    "slug": "settlemint",
    "scheme": "settlemint",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "online.settlemint.app"
    },
    "android": {
      "package": "online.settlemint.app",
      "adaptiveIcon": {
        "backgroundColor": "#3DD68C",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0f1219",
          "image": "./assets/splash-icon.png",
          "imageWidth": 200
        }
      ],
      "expo-secure-store"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "30e9f013-cb15-420b-86aa-957d03b8a6fa"
      }
    },
    "owner": "comrades-world",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/30e9f013-cb15-420b-86aa-957d03b8a6fa"
    }
  }
}
